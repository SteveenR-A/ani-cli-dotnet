<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:AniCS.Desktop.Converters"
             xmlns:models="clr-namespace:AniCS.Models;assembly=AniCS.Core"
             xmlns:views="clr-namespace:AniCS.Desktop.Views"
             xmlns:local="clr-namespace:AniCS.Desktop"
             xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="AniCS.Desktop.Views.AnimeDetailsView"
             x:DataType="models:AnimeResult">
    
    <UserControl.Resources>
        <converters:AsyncImageLoader x:Key="AsyncImageLoader"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto, *" Margin="20">
        <!-- Back Button -->
        <Button Grid.Row="0" Background="Transparent" Foreground="{DynamicResource AppPrimaryColor}" BorderThickness="0" Margin="0,0,0,15" Cursor="Hand" Click="OnBackClicked">
            <StackPanel Orientation="Horizontal" Spacing="5">
                <material:MaterialIcon Kind="ArrowLeft" Width="20" Height="20" />
                <TextBlock Text="Volver" VerticalAlignment="Center" FontSize="16" />
            </StackPanel>
        </Button>
        
        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- Header: Cover, Title, Synopsis -->
                <Grid ColumnDefinitions="200, *" Margin="0,0,0,20">
                    <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True" Width="200" VerticalAlignment="Top">
                        <Image Name="CoverImage"
                               converters:AsyncImageLoader.SourceUrl="{Binding ThumbnailUrl}"
                               Stretch="Uniform" />
                    </Border>
                    
                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                        <SelectableTextBlock Name="TitleText" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppTitleColor}" TextWrapping="Wrap" Margin="0,0,0,10" />
                        
                        <!-- Metadatos -->
                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="{Binding Type, StringFormat='Tipo: {0}'}" IsVisible="{Binding Type, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Foreground="{DynamicResource AppPrimaryColor}" FontWeight="Bold" Margin="0,0,15,5" />
                            <TextBlock Text="{Binding Status, StringFormat='Estado: {0}'}" IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Foreground="#A0A0B0" Margin="0,0,15,5" />
                            <TextBlock Text="{Binding Season, StringFormat='Temporada: {0}'}" IsVisible="{Binding Season, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Foreground="#A0A0B0" Margin="0,0,15,5" />
                            <TextBlock Text="{Binding Studios, StringFormat='Estudio: {0}'}" IsVisible="{Binding Studios, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Foreground="#A0A0B0" Margin="0,0,15,5" />
                        </WrapPanel>
                        
                        <TextBlock Name="SynopsisText" FontSize="16" Foreground="{DynamicResource AppSubtextColor}" TextWrapping="Wrap" Text="Cargando sinopsis..." Margin="0,0,0,15" />
                        
                        <!-- Generos y Extras -->
                        <StackPanel IsVisible="{Binding Genres.Count}">
                            <TextBlock Text="Géneros:" FontWeight="Bold" Foreground="{DynamicResource AppTitleColor}" Margin="0,0,0,5" />
                            <ItemsControl ItemsSource="{Binding Genres}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#2A2A40" CornerRadius="4" Padding="8,4" Margin="0,0,5,5">
                                            <TextBlock Text="{Binding}" Foreground="{DynamicResource AppPrimaryColor}" FontSize="12" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Grid>
                
                <!-- Episodes List -->
                <StackPanel>
                    <TextBlock Name="StatusText" Text="Cargando episodios..." FontSize="18" Foreground="{DynamicResource AppSubtextColor}" HorizontalAlignment="Center" Margin="0,0,0,15" IsVisible="True" TextWrapping="Wrap"/>
                    <ItemsControl Name="EpisodesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="views:EpisodeViewModel">
                                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,5">
                                    <Button Grid.Column="0" Background="{DynamicResource AppSurfaceColor}" 
                                            CornerRadius="4,0,0,4" 
                                            Padding="15,10" 
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            BorderThickness="1,1,0,1"
                                            BorderBrush="#333333"
                                            Click="OnEpisodeClicked">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="{Binding EpisodeNumber}" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryColor}" Width="40"/>
                                            <SelectableTextBlock Text="{Binding Title}" Foreground="{DynamicResource AppTitleColor}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Button>
                                    <Grid Grid.Column="1" ColumnDefinitions="*, Auto, Auto" IsVisible="{Binding IsDownloadButtonVisible}">
                                        <Button Grid.Column="0" Background="{DynamicResource AppSurfaceColor}" 
                                                CornerRadius="0,4,4,0" 
                                                Padding="15,10" 
                                                IsEnabled="{Binding CanDownload}"
                                                BorderThickness="1"
                                                BorderBrush="#333333"
                                                Click="OnDownloadEpisodeClicked">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <material:MaterialIcon Kind="{Binding DownloadIcon}" Width="16" Height="16" />
                                                <TextBlock Text="{Binding DownloadText}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" IsVisible="{Binding IsDownloading}"
                                                Click="OnCancelDownloadClicked"
                                                Background="#E53935" Foreground="White"
                                                ToolTip.Tip="Cancelar descarga"
                                                Margin="5,0,0,0">
                                            <material:MaterialIcon Kind="Close" Width="16" Height="16" />
                                        </Button>
                                        <Button Grid.Column="2" IsVisible="{Binding IsDownloaded}"
                                                Click="OnDeleteDownloadedEpisodeClicked"
                                                Background="#E53935" Foreground="White"
                                                ToolTip.Tip="Eliminar episodio descargado"
                                                Margin="5,0,0,0">
                                            <material:MaterialIcon Kind="TrashCan" Width="16" Height="16" />
                                        </Button>
                                    </Grid>

                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
