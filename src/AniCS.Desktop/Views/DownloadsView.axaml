<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:AniCS.Desktop.Services"
             xmlns:converters="clr-namespace:AniCS.Desktop.Converters"
             xmlns:views="clr-namespace:AniCS.Desktop.Views"
             xmlns:local="clr-namespace:AniCS.Desktop"
             xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AniCS.Desktop.Views.DownloadsView">
    
    <UserControl.Resources>
        <converters:AsyncImageLoader x:Key="AsyncImageLoader"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto, *" Margin="20">
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <Button Name="ReloadButton" Background="Transparent" Foreground="{DynamicResource AppTitleColor}" VerticalAlignment="Center" Click="OnReloadClicked" ToolTip.Tip="Recargar">
                <material:MaterialIcon Kind="Refresh" Width="24" Height="24" />
            </Button>
        </StackPanel>
        
        <Grid Grid.Row="1">
            <ScrollViewer>
                <StackPanel>
                    <!-- Active Downloads Section -->
                    <Border IsVisible="{Binding HasActiveDownloads, RelativeSource={RelativeSource AncestorType=views:DownloadsView}}"
                            Margin="0,0,0,20" Padding="15" Background="{DynamicResource AppSurfaceColor}" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Descargas Activas" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryColor}" Margin="0,0,0,10"/>
                            <ItemsControl Name="ActiveDownloadsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="services:ActiveDownload">
                                        <Border BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="10">
                                            <Grid ColumnDefinitions="50, *, Auto, Auto">
                                                <Border Grid.Column="0" CornerRadius="4" ClipToBounds="True" Margin="0,0,10,0">
                                                    <Image converters:AsyncImageLoader.SourceUrl="{Binding ThumbnailUrl}" Stretch="Uniform" VerticalAlignment="Top"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <SelectableTextBlock Text="{Binding AnimeTitle}" FontWeight="Bold" Foreground="{DynamicResource AppTitleColor}"/>
                                                    <SelectableTextBlock Text="{Binding EpisodeTitle}" Foreground="{DynamicResource AppTitleColor}" Opacity="0.9"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,5,0,0">
                                                        <material:MaterialIcon Kind="{Binding StatusIcon}" Width="14" Height="14" Foreground="{DynamicResource AppPrimaryColor}" />
                                                        <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{DynamicResource AppPrimaryColor}" />
                                                    </StackPanel>
                                                    <ProgressBar Value="{Binding Progress}" Maximum="100" Height="4" Margin="0,5,10,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                    <Button Click="OnPauseResumeActiveDownloadClicked" Tag="{Binding}" Background="#FFB300" Foreground="White">
                                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                                            <material:MaterialIcon Kind="{Binding PauseResumeIcon}" Width="16" Height="16" />
                                                            <TextBlock Text="{Binding PauseResumeText}" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Click="OnCancelActiveDownloadClicked" Tag="{Binding}" Background="#E53935" Foreground="White">
                                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                                            <material:MaterialIcon Kind="Close" Width="16" Height="16" />
                                                            <TextBlock Text="Cancelar" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    
                    <!-- Completed Downloads Section -->
                    <TextBlock Name="StatusText" Text="No hay animes descargados." FontSize="18" Foreground="{DynamicResource AppSubtextColor}" HorizontalAlignment="Center" Margin="0,20,0,0" IsVisible="False"/>
                    <ItemsControl Name="AnimeList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="services:DownloadedAnime">
                                <Expander Margin="0,0,0,15" Background="{DynamicResource AppSurfaceColor}" CornerRadius="8">
                                    <Expander.Header>
                                        <Grid ColumnDefinitions="100, *, Auto" Margin="5">
                                            <Border Grid.Column="0" CornerRadius="4" ClipToBounds="True">
                                                <Image converters:AsyncImageLoader.SourceUrl="{Binding ThumbnailUrl}" Stretch="Uniform" VerticalAlignment="Top"/>
                                            </Border>
                                            <SelectableTextBlock Grid.Column="1" Text="{Binding Title}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AppTitleColor}" TextWrapping="Wrap" Margin="15,0" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                <Button Content="Ver Online" Click="OnGoToAnimeClicked" Tag="{Binding}" Background="#1E88E5" Foreground="White" />
                                                <Button Click="OnDeleteAnimeClicked" Tag="{Binding}" Background="#E53935" Foreground="White">
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <material:MaterialIcon Kind="Delete" Width="16" Height="16" />
                                                        <TextBlock Text="Eliminar Anime" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Expander.Header>
                                    
                                    <ItemsControl ItemsSource="{Binding Episodes}" Margin="10">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="services:DownloadedEpisode">
                                                <Border BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="10">
                                                    <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                                                        <TextBlock Grid.Column="0" Text="{Binding EpisodeNumber}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryColor}" Width="40" VerticalAlignment="Center"/>
                                                        <SelectableTextBlock Grid.Column="1" Text="{Binding EpisodeTitle}" FontSize="16" Foreground="{DynamicResource AppSubtextColor}" VerticalAlignment="Center" Margin="10,0"/>
                                                        
                                                        <Button Grid.Column="2" Click="OnPlayEpisodeClicked" Tag="{Binding}" Margin="0,0,10,0" Background="#43A047" Foreground="White">
                                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                                <material:MaterialIcon Kind="Play" Width="16" Height="16" />
                                                                <TextBlock Text="Reproducir" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Button Grid.Column="3" Click="OnDeleteEpisodeClicked" Tag="{Binding}" Background="#E53935" Foreground="White">
                                                            <material:MaterialIcon Kind="Delete" Width="16" Height="16" />
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
