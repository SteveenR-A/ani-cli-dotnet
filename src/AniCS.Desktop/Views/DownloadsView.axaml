<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:AniCS.Desktop.Services"
             xmlns:converters="clr-namespace:AniCS.Desktop.Converters"
             xmlns:views="clr-namespace:AniCS.Desktop.Views"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="AniCS.Desktop.Views.DownloadsView">
    
    <UserControl.Resources>
        <converters:AsyncImageLoader x:Key="AsyncImageLoader"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto, *" Margin="20">
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <Button Name="ReloadButton" Content="🔄" FontSize="18" Padding="8,4" Background="Transparent" Foreground="{DynamicResource AppTitleColor}" VerticalAlignment="Center" Click="OnReloadClicked" ToolTip.Tip="Recargar"/>
        </StackPanel>
        
        <Grid Grid.Row="1">
            <ScrollViewer>
                <StackPanel>
                    <!-- Active Downloads Section -->
                    <Border IsVisible="{Binding HasActiveDownloads, RelativeSource={RelativeSource AncestorType=views:DownloadsView}}"
                            Margin="0,0,0,20" Padding="15" Background="{DynamicResource AppSurfaceColor}" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Descargas Activas" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryColor}" Margin="0,0,0,10"/>
                            <ItemsControl Name="ActiveDownloadsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="services:ActiveDownload">
                                        <Border BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="10">
                                            <Grid ColumnDefinitions="50, *, Auto, Auto">
                                                <Border Grid.Column="0" CornerRadius="4" ClipToBounds="True" Margin="0,0,10,0">
                                                    <Image converters:AsyncImageLoader.SourceUrl="{Binding ThumbnailUrl}" Stretch="Uniform" VerticalAlignment="Top"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding AnimeTitle}" FontWeight="Bold" Foreground="{DynamicResource AppTitleColor}"/>
                                                    <TextBlock Text="{Binding EpisodeTitle}" Foreground="{DynamicResource AppTitleColor}" Opacity="0.9"/>
                                                    <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{DynamicResource AppPrimaryColor}" Margin="0,5,0,0"/>
                                                    <ProgressBar Value="{Binding Progress}" Maximum="100" Height="4" Margin="0,5,10,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                    <Button Content="{Binding PauseResumeText}" Click="OnPauseResumeActiveDownloadClicked" Tag="{Binding}" Background="#FFB300" Foreground="White" />
                                                    <Button Content="❌ Cancelar" Click="OnCancelActiveDownloadClicked" Tag="{Binding}" Background="#E53935" Foreground="White" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    
                    <!-- Completed Downloads Section -->
                    <TextBlock Name="StatusText" Text="No hay animes descargados." FontSize="18" Foreground="{DynamicResource AppSubtextColor}" HorizontalAlignment="Center" Margin="0,20,0,0" IsVisible="False"/>
                    <ItemsControl Name="AnimeList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="services:DownloadedAnime">
                                <Expander Margin="0,0,0,15" Background="{DynamicResource AppSurfaceColor}" CornerRadius="8">
                                    <Expander.Header>
                                        <Grid ColumnDefinitions="100, *, Auto" Margin="5">
                                            <Border Grid.Column="0" CornerRadius="4" ClipToBounds="True">
                                                <Image converters:AsyncImageLoader.SourceUrl="{Binding ThumbnailUrl}" Stretch="Uniform" VerticalAlignment="Top"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AppTitleColor}" TextWrapping="Wrap" Margin="15,0" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                <Button Content="Ver Online" Click="OnGoToAnimeClicked" Tag="{Binding}" Background="#1E88E5" Foreground="White" />
                                                <Button Content="🗑️ Eliminar Anime" Click="OnDeleteAnimeClicked" Tag="{Binding}" Background="#E53935" Foreground="White" />
                                            </StackPanel>
                                        </Grid>
                                    </Expander.Header>
                                    
                                    <ItemsControl ItemsSource="{Binding Episodes}" Margin="10">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="services:DownloadedEpisode">
                                                <Border BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="10">
                                                    <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                                                        <TextBlock Grid.Column="0" Text="{Binding EpisodeNumber}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryColor}" Width="40" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding EpisodeTitle}" FontSize="16" Foreground="{DynamicResource AppSubtextColor}" VerticalAlignment="Center" Margin="10,0"/>
                                                        
                                                        <Button Grid.Column="2" Content="▶ Reproducir" Click="OnPlayEpisodeClicked" Tag="{Binding}" Margin="0,0,10,0" Background="#43A047" Foreground="White" />
                                                        <Button Grid.Column="3" Content="🗑️" Click="OnDeleteEpisodeClicked" Tag="{Binding}" Background="#E53935" Foreground="White"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
