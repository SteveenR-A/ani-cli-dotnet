<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:AniCS.Models;assembly=AniCS.Core"
             xmlns:controls="clr-namespace:AniCS.Desktop.Controls"
             xmlns:views="clr-namespace:AniCS.Desktop.Views"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="AniCS.Desktop.Views.CalendarView">
    
    <Grid RowDefinitions="Auto, *" Margin="20">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="15" Margin="0,0,0,15">
            <TextBlock Text="Calendario Semanal" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppTitleColor}" VerticalAlignment="Center"/>
            <Button Name="ReloadButton" Content="🔄 Recargar" FontSize="14" Padding="8,4" Background="{DynamicResource AppPrimaryColor}" Foreground="{DynamicResource AppPrimaryForegroundColor}" VerticalAlignment="Center" Click="OnReloadClicked"/>
        </StackPanel>
        
        <Grid Grid.Row="1">
            <TextBlock Name="StatusText" Text="Cargando calendario..." FontSize="18" Foreground="{DynamicResource AppSubtextColor}" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="True"/>
            <ScrollViewer>
                <ItemsControl Name="DayList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="views:CalendarDayGroup">
                            <StackPanel Margin="0,0,0,20">
                                <Border Background="#1A1A2E" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                                    <TextBlock Text="{Binding DayName}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryColor}"/>
                                </Border>
                                <ItemsControl ItemsSource="{Binding Animes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:AnimeResult">
                                            <controls:AnimeBlockControl />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
