<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="AniCS.Desktop.Views.SettingsView">
    <ScrollViewer>
        <StackPanel Margin="20" Spacing="20" MaxWidth="600" HorizontalAlignment="Left">
            
            <TextBlock Text="Configuración" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryColor}" Margin="0,0,0,10"/>

            <StackPanel Spacing="5">
                <TextBlock Text="Límite de imágenes en caché" FontWeight="Bold" Foreground="{DynamicResource AppTitleColor}"/>
                <TextBlock Text="Número máximo de portadas que se mantendrán en el disco." FontSize="12" Foreground="{DynamicResource AppSubtextColor}"/>
                <NumericUpDown Name="CacheLimitInput" Minimum="0" Maximum="1000" FormatString="0" />
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Reproductor Predeterminado" FontWeight="Bold" Foreground="{DynamicResource AppTitleColor}"/>
                <TextBlock Text="El reproductor a lanzar (Mpv, Vlc, o Auto para detectar)." FontSize="12" Foreground="{DynamicResource AppSubtextColor}"/>
                <ComboBox Name="PlayerComboBox" SelectedIndex="0" HorizontalAlignment="Stretch">
                    <ComboBoxItem>Auto</ComboBoxItem>
                    <ComboBoxItem>Mpv</ComboBoxItem>
                    <ComboBoxItem>Vlc</ComboBoxItem>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Ruta personalizada del reproductor (Opcional)" FontWeight="Bold" Foreground="{DynamicResource AppTitleColor}"/>
                <TextBlock Text="Si tu reproductor no está en las variables de entorno, pon aquí la ruta al .exe" FontSize="12" Foreground="{DynamicResource AppSubtextColor}"/>
                <TextBox Name="CustomPlayerPathInput" PlaceholderText="C:\Ruta\A\mpv.exe" />
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Tema Visual" FontWeight="Bold" Foreground="{DynamicResource AppTitleColor}"/>
                <ComboBox Name="ThemeComboBox" HorizontalAlignment="Stretch" SelectionChanged="OnThemeSelectionChanged">
                    <ComboBoxItem Content="Default (Oscuro)" Tag="Dark"/>
                    <ComboBoxItem Content="Claro" Tag="Light"/>
                    <ComboBoxItem Content="Dracula" Tag="Dracula"/>
                    <ComboBoxItem Content="Tokyo Night" Tag="TokyoNight"/>
                    <ComboBoxItem Content="Cyberpunk" Tag="Cyberpunk"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Paradigma de Interfaz" FontWeight="Bold" Foreground="{DynamicResource AppTitleColor}"/>
                <TextBlock Text="El estilo y layout general de la aplicación. (Requiere reiniciar para aplicar los experimentales)" FontSize="12" Foreground="{DynamicResource AppSubtextColor}"/>
                <ComboBox Name="ParadigmComboBox" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="Lista (Por Defecto)" Tag="Normal"/>
                    <ComboBoxItem Content="TUI Avanzada (ASCII)" Tag="ASCII"/>
                    <ComboBoxItem Content="App Móvil (Carruseles)" Tag="AndroidApp"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="HUD Espacial (Experimental)" FontWeight="Bold" Foreground="{DynamicResource AppTitleColor}"/>
                <TextBlock Text="Muestra un menú radial al seleccionar episodios en lugar de botones clásicos." FontSize="12" Foreground="{DynamicResource AppSubtextColor}"/>
                <ToggleSwitch Name="UseSpatialHudToggle" OffContent="Desactivado" OnContent="Activado" />
            </StackPanel>



            <Button Content="Guardar Cambios" 
                    Padding="20,10"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Left"
                    Click="OnSaveClicked"/>
            
            <TextBlock Name="StatusMessage" Foreground="#4CAF50" FontWeight="Bold" IsVisible="False"/>

            <StackPanel Margin="0,30,0,0">
                <Separator Background="#44444460" Margin="0,0,0,10"/>
                <TextBlock Text="Acerca de AniCS" FontWeight="Bold" Foreground="{DynamicResource AppTitleColor}"/>
                <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,5,0,0">
                    <TextBlock Name="AppVersionText" Text="Versión: Desconocida" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource AppSubtextColor}"/>
                    <Button Content="Ver Notas de Parche" Cursor="Hand" Click="OnViewChangelogClicked"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
