<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:AniCS.Models;assembly=AniCS.Core"
             xmlns:converters="clr-namespace:AniCS.Desktop.Converters"
             x:Class="AniCS.Desktop.Controls.AnimeBlockControl"
             x:DataType="models:AnimeResult"
             Margin="0,0,0,10">
    <UserControl.Resources>
        <converters:AsyncImageLoader x:Key="AsyncImageLoader"/>
    </UserControl.Resources>

    <Button Background="{DynamicResource AppSurfaceColor}" 
            CornerRadius="8" 
            Padding="0" 
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Left"
            BorderThickness="1"
            BorderBrush="#333333"
            Click="OnBlockClicked">
        
        <Grid ColumnDefinitions="Auto, *">
            <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True" Width="220" VerticalAlignment="Top">
                <Image converters:AsyncImageLoader.SourceUrl="{Binding ThumbnailUrl}" Stretch="Uniform" />
            </Border>
            
            <!-- Detalles -->
            <StackPanel Grid.Column="1" Margin="15,10">
                <TextBlock Text="{Binding Title}" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource AppTitleColor}" 
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap"
                           Margin="0,0,0,8" />
                
                <TextBlock Text="{Binding Description}" 
                           FontSize="14" 
                           Foreground="{DynamicResource AppSubtextColor}"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="4"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </Button>
</UserControl>
