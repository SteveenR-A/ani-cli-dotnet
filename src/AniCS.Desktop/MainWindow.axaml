<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:AniCS.Desktop.Views"
        xmlns:local="clr-namespace:AniCS.Desktop"
        xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="AniCS.Desktop.MainWindow"
        Title="AniCS Desktop"
        Icon="avares://AniCS.Desktop/Assets/Incono/favicon.ico"
        WindowStartupLocation="CenterScreen">
        
    <Grid RowDefinitions="Auto, *">
        <!-- Top Navigation Bar -->
        <Border Grid.Row="0" Background="{DynamicResource AppSurfaceColor}" Height="60" Padding="5,0">
            <Grid ColumnDefinitions="Auto, *">
                <Button Grid.Column="0" Name="HamburgerButton" 
                        Background="Transparent" 
                        Foreground="{DynamicResource AppPrimaryColor}" 
                        Click="OnHamburgerClicked" 
                        Margin="0,0,20,0"
                        VerticalAlignment="Center">
                    <material:MaterialIcon Kind="Menu" Width="24" Height="24" />
                </Button>
                <TextBlock Grid.Column="1" Name="PageTitleText" Text="Inicio" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource AppPrimaryColor}" 
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
            </Grid>
        </Border>

        <!-- Main Content with SplitView -->
        <SplitView Grid.Row="1" Name="MainSplitView" 
                   IsPaneOpen="False" 
                   DisplayMode="Overlay" 
                   OpenPaneLength="250" 
                   PaneBackground="{DynamicResource AppSurfaceColor}">
            <SplitView.Pane>
                <Grid RowDefinitions="*, Auto">
                    <StackPanel Grid.Row="0" Margin="20" Spacing="15">
                    <Button Content="Inicio" 
                            Classes="SidebarBtn"
                            Background="Transparent"
                            Foreground="{DynamicResource AppTitleColor}"
                            FontSize="16"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Click="OnHomeClicked"/>
                            
                    <Button Content="Buscar Anime" 
                            Classes="SidebarBtn"
                            Background="Transparent"
                            Foreground="{DynamicResource AppSubtextColor}"
                            FontSize="16"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Click="OnSearchClicked"/>
                            
                    <Button Content="Calendario" 
                            Classes="SidebarBtn"
                            Background="Transparent"
                            Foreground="{DynamicResource AppSubtextColor}"
                            FontSize="16"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Click="OnCalendarClicked"/>

                    <Button Content="Descargas" 
                            Classes="SidebarBtn"
                            Background="Transparent"
                            Foreground="{DynamicResource AppSubtextColor}"
                            FontSize="16"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Click="OnDownloadsClicked"/>
                            
                    <Button Content="Historial" 
                            Classes="SidebarBtn"
                            Background="Transparent"
                            Foreground="{DynamicResource AppSubtextColor}"
                            FontSize="16"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Click="OnHistoryClicked"/>

                    </StackPanel>

                    <Button Grid.Row="1"
                            Classes="SidebarBtn"
                            Background="Transparent"
                            Foreground="{DynamicResource AppSubtextColor}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Margin="20,10,20,20"
                            Click="OnSettingsClicked">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <material:MaterialIcon Kind="Cog" Width="20" Height="20" />
                            <TextBlock Text="Ajustes" VerticalAlignment="Center" FontSize="16" />
                        </StackPanel>
                    </Button>
                </Grid>
            </SplitView.Pane>

            <SplitView.Content>
                <Border Background="{DynamicResource AppBackgroundColor}">
                    <ContentControl Name="MainContent">
                        <!-- Loaded dynamically -->
                    </ContentControl>
                </Border>
            </SplitView.Content>
        </SplitView>
    </Grid>
</Window>
